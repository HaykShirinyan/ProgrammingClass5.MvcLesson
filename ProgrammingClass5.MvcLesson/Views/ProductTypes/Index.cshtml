@model List<ProductType>

<div>
    <a asp-controller="ProductTypes" asp-action="Create" class="btn btn-primary">
        Create ProductType
    </a>
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
            </tr>
        </thead>

        <tbody>
            @foreach (ProductType productTypes in Model)
            {
                <tr>
                    <td>@productTypes.Id</td>
                    <td>@productTypes.Name</td>
                    <td>@productTypes.Description</td>
                    <td>
                        <a asp-controller="ProductTypes" asp-action="Edit" asp-route-id="@productTypes.Id" class="btn btn-secondary">
                            Edit
                        </a>
                    </td>
                </tr>

            }
        </tbody>
    </table>
</div>